# LLM Firewall — Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=llm_firewall

# Redis
REDIS_URL=redis://localhost:6379

# ML Model
MODEL_PATH=models/
DEFAULT_THRESHOLD=0.50

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000

# Security
API_KEY_PEPPER=change_me_to_a_random_string_in_production
SYSTEM_CANARY=FW_SYS_8f3a2b91
MASTER_API_KEY=

# FAISS Similarity
FAISS_INDEX_PATH=data/faiss/attack_index.faiss
FAISS_TEXTS_PATH=data/faiss/attack_texts.json
EMBEDDING_SIMILARITY_THRESHOLD=0.85

# Monitoring
OUTPUT_MONITORING_ENABLED=true
